def strip_salutation(text):
    """Remove any sign-off block Claude may have appended."""
    patterns = [
        r'\n+Yours sincerely[\s\S]*$',
        r'\n+Kind regards[\s\S]*$',
        r'\n+Best regards[\s\S]*$',
        r'\n+Sincerely[\s\S]*$',
    ]
    for pat in patterns:
        text = re.sub(pat, '', text, flags=re.IGNORECASE)
    return text.rstrip()

