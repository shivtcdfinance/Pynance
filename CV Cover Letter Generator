    kw_path.write_text(kw_content, encoding='utf-8')
    print(f"✅ Keywords Comparison: {kw_path.name}")

    # 4. Metadata
    meta_path = folder_path / "metadata.txt"
    meta_path.write_text(f"""METADATA
